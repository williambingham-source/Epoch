# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Vision provider — anthropic (default) | openai | gemini | ollama
VISION_PROVIDER=anthropic

# API keys — only the one matching VISION_PROVIDER is required
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=

# Override the model within the chosen provider (leave blank for default)
VISION_MODEL=

# Ollama base URL (only needed if VISION_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
